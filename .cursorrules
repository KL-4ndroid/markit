### 頁面結構
```tsx
export default function PageName() {
  return (
    <div className="min-h-screen bg-[#FAFAF8]">
      {/* Header with gradient */}
      <div className="bg-gradient-to-br from-[#7B9FA6] to-[#D4A574] pt-12 pb-8 px-6 rounded-b-[2rem]">
        <div className="max-w-lg mx-auto">
          <h1 className="text-2xl font-medium text-white opacity-90">標題</h1>
        </div>
      </div>

      {/* Content */}
      <div className="max-w-lg mx-auto px-6 -mt-4">
        {/* 內容 */}
      </div>
    </div>
  );
}
```

### 命名規範
- 組件：PascalCase (例：BottomNavigation)
- 函數：camelCase (例：formatDate)
- 常數：UPPER_SNAKE_CASE (例：MAX_ITEMS)
- 檔案：與組件同名或小寫 (page.tsx, utils.ts)

## 開發約束

### 禁止事項
❌ 不允許圖片上傳或 Base64 儲存
❌ 不直接從 Supabase 讀取資料渲染 UI
❌ 不使用 Emoji 圖片（使用 Lucide Icons）
❌ 不偏離設計系統色彩
❌ 不在主執行緒執行同步操作（會阻塞 UI）

### 必須遵循
✅ 使用 CSS 變數 + Tailwind token 色彩（不要寫 hex）
✅ 所有資料存於 IndexedDB (Dexie.js)
✅ 所有讀取使用 `useLiveQuery` 或自訂 Hooks
✅ 使用事件溯源模式
✅ 背景同步至 Supabase（非阻塞）
✅ 單手操作優化（按鈕至少 44x44px）
✅ 頁面底部預留 pb-24 給導航
✅ 使用 max-w-lg mx-auto 限制內容寬度
✅ 添加適當的 transition 動畫

## 資料庫規範

### Local-First 資料流

#### 寫入流程（必須遵循）

```typescript
// ✅ 正確：Local-First 寫入流程
import { recordEvent } from '@/lib/db/events';

async function handleUserAction(data: any) {
  // 步驟 1: 寫入本地 Dexie（立即完成）
  await recordEvent({
    type: 'market_created',
    payload: data,
    timestamp: Date.now(),
    actor_id: userId,
    market_id: marketId,
  });
  
  // 步驟 2: UI 自動更新（useLiveQuery 觸發）
  // 不需要手動更新狀態
  
  // 步驟 3: 背景同步（由 useSync Hook 自動處理）
  // 失敗會自動重試，不影響用戶體驗
}

// ❌ 錯誤：直接寫入 Supabase
async function handleUserAction(data: any) {
  await supabase.from('markets').insert(data); // 斷網會失敗
}

// ❌ 錯誤：同時寫入兩處
async function handleUserAction(data: any) {
  await db.markets.add(data);
  await supabase.from('markets').insert(data); // 重複邏輯
}
```

#### 讀取流程（必須遵循）

```typescript
// ✅ 正確：從 Dexie 讀取
import { useLiveQuery } from 'dexie-react-hooks';
import { db } from '@/lib/db';

function MarketsList() {
  const markets = useLiveQuery(
    () => db.markets
      .where('status')
      .equals('paid')
      .toArray()
  );
  
  if (!markets) return <Loading />;
  
  return (
    <div>
      {markets.map(market => (
        <MarketCard key={market.id} market={market} />
      ))}
    </div>
  );
}

// ✅ 正確：使用自訂 Hook
import { useMarkets } from '@/lib/db/hooks';

function MarketsList() {
  const markets = useMarkets({ 
    orderBy: 'startDate', 
    order: 'desc' 
  });
  
  if (!markets) return <Loading />;
  
  return (
    <div>
      {markets.map(market => (
        <MarketCard key={market.id} market={market} />
      ))}
    </div>
  );
}

// ❌ 錯誤：從 Supabase 讀取
function MarketsList() {
  const [markets, setMarkets] = useState([]);
  
  useEffect(() => {
    supabase
      .from('markets')
      .select('*')
      .then(({ data }) => setMarkets(data)); // 違反 Local-First
  }, []);
  
  // ...
}

// ❌ 錯誤：混合讀取
function MarketsList() {
  const localMarkets = useLiveQuery(() => db.markets.toArray());
  const [cloudMarkets, setCloudMarkets] = useState([]);
  
  // 不應該有兩個資料來源
}
```

#### 雲端回流（由 useSync 自動處理）

```typescript
// ✅ 正確：雲端資料必須先寫入 Dexie
async function pullEventsFromCloud(userId: string) {
  // 1. 從 Supabase 拉取新事件
  const { data: newEvents } = await supabase
    .from('events')
    .select('*')
    .gt('timestamp', lastSyncAt);
  
  // 2. 寫入本地 Dexie
  for (const event of newEvents) {
    await db.events.add({
      ...event,
      sync_status: 'synced',
    });
    
    // 3. 觸發事件處理器（更新快照表）
    const handler = eventHandlers[event.type];
    if (handler) {
      await handler(event, db);
    }
  }
  
  // 4. UI 自動更新（useLiveQuery 觸發）
}

// ❌ 錯誤：直接使用雲端資料更新 UI
async function pullEventsFromCloud(userId: string) {
  const { data: markets } = await supabase
    .from('markets')
    .select('*');
  
  setMarkets(markets); // 違反 Local-First
}
```

### 事件溯源架構
- ✅ 所有操作記錄為不可變事件
- ✅ 維護快照表以供快速讀取
- ✅ 使用 transaction 確保原子性
- ✅ 可從事件歷史重建快照

### 資料表結構
- **events**: 歷史事件（不可變，唯一真實來源）
- **markets**: 市集快照（從 events 計算得出）
- **products**: 商品清單（⚠️ 禁止圖片欄位）
- **dailyStats**: 每日統計（從 events 計算得出）
- **settings**: 用戶設定

### 同步機制

```typescript
// ✅ 正確：使用 useSync Hook
import { useSync } from '@/hooks/useSync';

function MyComponent() {
  const { status, lastSyncAt, pendingCount, sync } = useSync({
    enabled: true,
    interval: 30000, // 30 秒自動同步
  });
  
  // 手動觸發同步
  const handleManualSync = () => {
    sync();
  };
  
  return (
    <div>
      <p>同步狀態: {status}</p>
      <p>待同步事件: {pendingCount}</p>
      <button onClick={handleManualSync}>立即同步</button>
    </div>
  );
}

// ❌ 錯誤：自己實作同步邏輯
function MyComponent() {
  useEffect(() => {
    const interval = setInterval(async () => {
      // 不應該自己實作同步
      await supabase.from('events').insert(localEvents);
    }, 30000);
    
    return () => clearInterval(interval);
  }, []);
}
```

### 事件類型
- 市集：market_created, market_updated, market_status_changed, market_started, market_ended, market_deleted
- 商品：product_created, product_updated, product_deleted
- 互動：interaction_recorded, deal_closed
- 設定：settings_updated

