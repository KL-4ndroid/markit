# Supabase Configuration
# Required for multi-user collaboration and cloud sync
# Get these values from your Supabase project dashboard (Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Backend API boundary (Vercel BFF)
# Web builds should normally leave this unset and use same-origin /api routes.
# Every mobile build must set the stable HTTPS Vercel staging or production origin.
# Never use a temporary Preview Deployment URL in a released iOS binary.
NEXT_PUBLIC_API_BASE_URL=https://markit-app-mocha.vercel.app

# Exact comma-separated browser origins allowed to call authenticated API routes.
# Keep the production Web origin and the Capacitor origin; never use `*` or `null`.
APP_API_CORS_ALLOWED_ORIGINS=https://markit-app-mocha.vercel.app,capacitor://localhost

# Keep APP_BUILD_TARGET unset in the Vercel Web/BFF project. The local
# build:mobile script sets the mobile target only for the static iOS artifact.
# APP_BUILD_TARGET=

# Optional: Set to 'true' to enable debug mode (localhost only)
NEXT_PUBLIC_DEBUG_MODE=false

# Optional: Analytics configuration
NEXT_PUBLIC_ANALYTICS_ENABLED=true

# Sales photo evidence runtime
# Local development is enabled by default; set to 0 to disable it locally.
# Staging requires both NEXT_PUBLIC_APP_ENV=staging and the value 1 below.
# Production client builds require NEXT_PUBLIC_APP_ENV=production plus both
# public runtime values set to 1. Server routes use Vercel's VERCEL_ENV first.
NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_SALES_PHOTO_EVIDENCE_RUNTIME_ENQUEUE_ENABLED=1
NEXT_PUBLIC_SALES_PHOTO_EVIDENCE_RUNTIME_ENQUEUE_ALLOW_PRODUCTION=0

# Enables /debug/sales-photo-evidence outside local development.
# Only staging/preview environments are accepted; production remains unavailable.
SALES_PHOTO_EVIDENCE_TEST_PAGE_ENABLED=0

# Vercel BFF route gates. Preview/staging requires *_ENABLED=1. Production also
# requires the matching *_ALLOW_PRODUCTION=1 after the staging smoke passes.
SALES_PHOTO_EVIDENCE_METADATA_CLAIM_ROUTE_ENABLED=0
SALES_PHOTO_EVIDENCE_METADATA_CLAIM_ROUTE_ALLOW_PRODUCTION=0
SALES_PHOTO_EVIDENCE_R2_UPLOAD_ROUTE_ENABLED=0
SALES_PHOTO_EVIDENCE_R2_UPLOAD_ROUTE_ALLOW_PRODUCTION=0
SALES_PHOTO_EVIDENCE_IMAGE_READ_ROUTE_ENABLED=0
SALES_PHOTO_EVIDENCE_IMAGE_READ_ROUTE_ALLOW_PRODUCTION=0

# Temporary, server-only fault gate for one explicitly approved cleanup smoke.
# It fails closed unless every value, the verified owner actor, the exact
# owner/market/sale scope, and both request headers match. Remove all values
# immediately after the smoke; never expose the token through NEXT_PUBLIC_.
SALES_PHOTO_EVIDENCE_FAULT_INJECTION_ENABLED=0
SALES_PHOTO_EVIDENCE_FAULT_INJECTION_ALLOW_PRODUCTION=0
SALES_PHOTO_EVIDENCE_FAULT_INJECTION_TOKEN=
SALES_PHOTO_EVIDENCE_FAULT_INJECTION_OWNER_ID=
SALES_PHOTO_EVIDENCE_FAULT_INJECTION_MARKET_ID=
SALES_PHOTO_EVIDENCE_FAULT_INJECTION_SALE_ID=

# Dedicated named Supabase server secret used only by the Vercel BFF mutation
# RPC client. Create a separate key per environment. It bypasses RLS, so never
# add NEXT_PUBLIC_, reuse it in a browser/mobile bundle, or commit a real value.
SUPABASE_SECRET_KEY=

# Cloudflare R2 credentials are server-only Vercel secrets. Never add a
# NEXT_PUBLIC_ prefix and never place real values in source control or mobile env.
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-private-r2-bucket
# R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
